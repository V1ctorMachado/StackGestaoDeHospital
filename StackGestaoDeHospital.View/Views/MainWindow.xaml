<Window x:Class="StackGestaoDeHospital.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestão de Atendimentos"
        Height="720"
        Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#111111">

    <Window.Resources>

        <Style x:Key="TituloColunaStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F1F1F1"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style x:Key="ColunaKanbanStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#151515"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="12,0"/>
            <Setter Property="MinHeight" Value="520"/>
        </Style>

        <Style x:Key="CardAtendimentoStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="#666"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#181818"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="TextoCardStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E8E8E8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="TextoCardMenorStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CFCFCF"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="BotaoProsseguirStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#F5F5F5"/>
            <Setter Property="Background" Value="#202020"/>
            <Setter Property="BorderBrush" Value="#777"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,4"/>
            <Setter Property="MinWidth" Value="95"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="ComboDepartamentoStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#151515"/>
            <Setter Property="Foreground" Value="#F5F5F5"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>

        <!-- Template reutilizável do card -->
        <DataTemplate x:Key="AtendimentoCardTemplate">
            <Border Style="{StaticResource CardAtendimentoStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="{Binding Id, StringFormat=Nº Atendimento: {0}}"
                               Style="{StaticResource TextoCardStyle}"
                               FontWeight="SemiBold"/>

                    <TextBlock Grid.Row="1"
                               Text="{Binding Paciente.Nome, StringFormat=Paciente: {0}}"
                               Style="{StaticResource TextoCardMenorStyle}"/>

                    <TextBlock Grid.Row="2"
                               Text="{Binding Especialidade.Descricao, StringFormat=Especialidade: {0}}"
                               Style="{StaticResource TextoCardMenorStyle}"/>

                    <TextBlock Grid.Row="3"
                               Text="{Binding Medico.Nome, StringFormat=Médico: {0}}"
                               Style="{StaticResource TextoCardMenorStyle}"/>

                    <TextBlock Grid.Row="4"
                               Text="{Binding Enfermeiro.Nome, StringFormat=Enfermeiro: {0}}"
                               Style="{StaticResource TextoCardMenorStyle}"/>

                    <TextBlock Grid.Row="5"
                               Text="{Binding Queixa, StringFormat=Queixa: {0}}"
                               Style="{StaticResource TextoCardMenorStyle}"
                               TextWrapping="Wrap"/>

                    <TextBlock Grid.Row="6"
                               Text="{Binding Data, StringFormat={}{0:dd/MM/yyyy HH:mm}}"
                               Style="{StaticResource TextoCardStyle}"
                               Margin="0,16,0,0"/>

                    <Button Grid.Row="7"
                            Content="Prosseguir →"
                            Style="{StaticResource BotaoProsseguirStyle}"
                            HorizontalAlignment="Right"
                            Margin="0,8,0,0"
                            Command="{Binding DataContext.ProsseguirCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}"/>
                </Grid>
            </Border>
        </DataTemplate>

    </Window.Resources>

    <Grid Margin="24">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Filtro superior -->
        <Grid Grid.Row="0" Margin="0,0,0,28">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="1">
                <TextBlock Text="Departamento:"
                           Foreground="#F1F1F1"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Margin="4,0,0,6"/>

                <ComboBox Style="{StaticResource ComboDepartamentoStyle}"
                          ItemsSource="{Binding Departamentos}"
                          SelectedItem="{Binding DepartamentoSelecionado}"
                          DisplayMemberPath="Nome"/>
            </StackPanel>
        </Grid>

        <!-- Quadro Kanban -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Aguardando -->
            <StackPanel Grid.Column="0">
                <TextBlock Text="Aguardando"
                           Style="{StaticResource TituloColunaStyle}"/>

                <Border Style="{StaticResource ColunaKanbanStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding AtendimentosAguardando}"
                                      ItemTemplate="{StaticResource AtendimentoCardTemplate}"/>
                    </ScrollViewer>
                </Border>
            </StackPanel>

            <!-- Triagem -->
            <StackPanel Grid.Column="1">
                <TextBlock Text="Triagem"
                           Style="{StaticResource TituloColunaStyle}"/>

                <Border Style="{StaticResource ColunaKanbanStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding AtendimentosTriagem}"
                                      ItemTemplate="{StaticResource AtendimentoCardTemplate}"/>
                    </ScrollViewer>
                </Border>
            </StackPanel>

            <!-- Em atendimento -->
            <StackPanel Grid.Column="2">
                <TextBlock Text="Em atendimento"
                           Style="{StaticResource TituloColunaStyle}"/>

                <Border Style="{StaticResource ColunaKanbanStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding AtendimentosEmAtendimento}"
                                      ItemTemplate="{StaticResource AtendimentoCardTemplate}"/>
                    </ScrollViewer>
                </Border>
            </StackPanel>

            <!-- Finalizado -->
            <StackPanel Grid.Column="3">
                <TextBlock Text="Finalizado"
                           Style="{StaticResource TituloColunaStyle}"/>

                <Border Style="{StaticResource ColunaKanbanStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding AtendimentosFinalizados}"
                                      ItemTemplate="{StaticResource AtendimentoCardTemplate}"/>
                    </ScrollViewer>
                </Border>
            </StackPanel>

        </Grid>
    </Grid>
</Window>