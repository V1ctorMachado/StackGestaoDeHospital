<Window x:Class="StackGestaoDeHospital.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestão de Atendimentos"
        Height="720"
        Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#111111">

    <Window.Resources>

        <Style x:Key="TituloColunaStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F1F1F1"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style x:Key="ColunaKanbanStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#151515"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="12,0"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
        </Style>

        <Style x:Key="CardAtendimentoStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="#666"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#181818"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="TextoCardStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E8E8E8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="TextoCardMenorStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CFCFCF"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="BotaoProsseguirStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#F5F5F5"/>
            <Setter Property="Background" Value="#202020"/>
            <Setter Property="BorderBrush" Value="#777"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,4"/>
            <Setter Property="MinWidth" Value="95"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="ComboDepartamentoStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
        </Style>

        <DataTemplate x:Key="AtendimentoCardTemplate">
            <Border Style="{StaticResource CardAtendimentoStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="{Binding Id, StringFormat=Nº Atendimento: {0}}"
                               Style="{StaticResource TextoCardStyle}"
                               FontWeight="SemiBold"/>

                    <TextBlock Grid.Row="1"
                               Style="{StaticResource TextoCardMenorStyle}">
                        <Run Text="Paciente: "/>
                        <Run Text="{Binding Paciente.NomeCompleto, Mode=OneWay, TargetNullValue='-', FallbackValue='-'}"/>
                    </TextBlock>

                    <TextBlock Grid.Row="2"
                               Style="{StaticResource TextoCardMenorStyle}">
                        <Run Text="Especialidade: "/>
                        <Run Text="{Binding Especialidade.Descricao, TargetNullValue='-', FallbackValue='-'}"/>
                    </TextBlock>

                    <TextBlock Grid.Row="3"
                               Style="{StaticResource TextoCardMenorStyle}">
                        <Run Text="Médico: "/>
                        <Run Text="{Binding Medico.NomeCompleto, Mode=OneWay, TargetNullValue='-', FallbackValue='-'}"/>
                    </TextBlock>

                    <TextBlock Grid.Row="4"
                               Style="{StaticResource TextoCardMenorStyle}">
                        <Run Text="Enfermeiro: "/>
                        <Run Text="{Binding Enfermeiro.NomeCompleto, Mode=OneWay, TargetNullValue='-', FallbackValue='-'}"/>
                    </TextBlock>

                    <TextBlock Grid.Row="5"
                               Text="{Binding Data, StringFormat={}{0:dd/MM/yyyy HH:mm}}"
                               Style="{StaticResource TextoCardStyle}"
                               Margin="0,16,0,0"/>

                    <Grid Grid.Row="6" Margin="0,8,0,0">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                            Content="Visualizar"
                            Style="{StaticResource BotaoProsseguirStyle}"
                            HorizontalAlignment="Left"
                            CommandParameter="{Binding}"
                            Click="VisualizarAtendimento"
                        />

                        <Button Grid.Column="2"
                            Content="Prosseguir →"
                            Style="{StaticResource BotaoProsseguirStyle}"
                            HorizontalAlignment="Right"
                            CommandParameter="{Binding}"
                            Click="ProsseguirAtendimento"
                        />
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>

    </Window.Resources>

    <Grid Margin="24">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Filtro superior -->
        <Grid Grid.Row="0" Margin="0,0,0,28">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="1">
                <TextBlock Text="Departamento:"
                           Foreground="#F1F1F1"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Margin="4,0,0,6"/>

                <ComboBox x:Name="ComboDepartamento"
                          Style="{StaticResource ComboDepartamentoStyle}"
                          ItemsSource="{Binding Departamentos}"
                          SelectedItem="{Binding DepartamentoSelecionado}"
                          DisplayMemberPath="Nome"
                          SelectionChanged="ChangeDepartamento"/>
            </StackPanel>
        </Grid>

        <!-- Quadro Kanban com scroll horizontal -->
        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled">

            <Grid MinWidth="1100">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="275"/>
                    <ColumnDefinition Width="275"/>
                    <ColumnDefinition Width="275"/>
                    <ColumnDefinition Width="275"/>
                </Grid.ColumnDefinitions>

                <!-- Aguardando -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Aguardando"
                               Style="{StaticResource TituloColunaStyle}"/>

                    <Border Grid.Row="1"
                            Style="{StaticResource ColunaKanbanStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding AtendimentosAguardando}"
                                          ItemTemplate="{StaticResource AtendimentoCardTemplate}"/>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <!-- Triagem -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Triagem"
                               Style="{StaticResource TituloColunaStyle}"/>

                    <Border Grid.Row="1"
                            Style="{StaticResource ColunaKanbanStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding AtendimentosTriagem}"
                                          ItemTemplate="{StaticResource AtendimentoCardTemplate}"/>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <!-- Em atendimento -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Em atendimento"
                               Style="{StaticResource TituloColunaStyle}"/>

                    <Border Grid.Row="1"
                            Style="{StaticResource ColunaKanbanStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding AtendimentosEmAtendimento}"
                                          ItemTemplate="{StaticResource AtendimentoCardTemplate}"/>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <!-- Finalizado -->
                <Grid Grid.Column="3">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Finalizado"
                               Style="{StaticResource TituloColunaStyle}"/>

                    <Border Grid.Row="1"
                            Style="{StaticResource ColunaKanbanStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding AtendimentosFinalizados}"
                                          ItemTemplate="{StaticResource AtendimentoCardTemplate}"/>
                        </ScrollViewer>
                    </Border>
                </Grid>

            </Grid>
        </ScrollViewer>

    </Grid>
</Window>