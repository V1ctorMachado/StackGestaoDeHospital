<Window x:Class="StackGestaoDeHospital.View.DetalhesAtendimento"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Detalhes do Atendimento"
        WindowStartupLocation="CenterOwner"
        WindowState="Maximized"
        Background="#111111">

    <Window.Resources>

        <Style x:Key="TituloSecaoStyle"
               TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F1F1F1"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style x:Key="LabelStyle"
               TargetType="TextBlock">
            <Setter Property="Foreground" Value="#B0B0B0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ValorStyle"
               TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E8E8E8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="CampoStyle"
               TargetType="TextBox">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="#E8E8E8"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="MinHeight" Value="32"/>
        </Style>

        <Style x:Key="ComboStyle"
               TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
        </Style>

        <Style x:Key="SeparadorStyle"
               TargetType="Separator">
            <Setter Property="Background" Value="#333"/>
            <Setter Property="Height" Value="1"/>
            <Setter Property="Margin" Value="0,24,0,24"/>
        </Style>

        <Style x:Key="GridCampoStyle"
               TargetType="Grid">
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="BotaoSalvarStyle"
               TargetType="Button">
            <Setter Property="Background" Value="#2E7D32"/>
            <Setter Property="Foreground" Value="#F1F1F1"/>
            <Setter Property="BorderBrush" Value="#1B5E20"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">

        <StackPanel Margin="24">

            <!-- DADOS DO ATENDIMENTO -->
            <TextBlock Text="Dados do Atendimento"
                       Style="{StaticResource TituloSecaoStyle}"/>

            <Grid Style="{StaticResource GridCampoStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Nº Atendimento:"
                           Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Column="1"
                           Text="{Binding Atendimento.Id, Mode=OneWay}"
                           Style="{StaticResource ValorStyle}"/>
            </Grid>

            <Grid Style="{StaticResource GridCampoStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Data:"
                           Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Column="1"
                           Text="{Binding Atendimento.Data, Mode=OneWay, StringFormat={}{0:dd/MM/yyyy HH:mm}}"
                           Style="{StaticResource ValorStyle}"/>
            </Grid>

            <Grid Style="{StaticResource GridCampoStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Status:"
                           Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Column="1"
                           Text="{Binding Atendimento.Status, Mode=OneWay}"
                           Style="{StaticResource ValorStyle}"/>
            </Grid>

            <Grid Style="{StaticResource GridCampoStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Queixa:"
                           Style="{StaticResource LabelStyle}"
                           VerticalAlignment="Top"
                           Margin="0,8,8,0"/>

                <TextBox Grid.Column="1"
                         x:Name="TextBoxQueixa"
                         Style="{StaticResource CampoStyle}"
                         Text="{Binding AtendimentoComando.Queixa, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         IsReadOnly="{Binding IsQueixaReadOnly, Mode=OneWay}"
                         MinHeight="60"/>
            </Grid>

            <Grid Style="{StaticResource GridCampoStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Especialidade:"
                           Style="{StaticResource LabelStyle}"/>

                <ComboBox Grid.Column="1"
                          x:Name="ComboEspecialidade"
                          Style="{StaticResource ComboStyle}"
                          ItemsSource="{Binding Especialidades, Mode=OneWay}"
                          SelectedItem="{Binding AtendimentoComando.Especialidade, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          DisplayMemberPath="Descricao"
                          IsEnabled="{Binding IsEspecialidadeEditavel, Mode=OneWay}"/>
            </Grid>

            <Grid Style="{StaticResource GridCampoStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Diagnóstico:"
                           Style="{StaticResource LabelStyle}"
                           VerticalAlignment="Top"
                           Margin="0,8,8,0"/>

                <TextBox Grid.Column="1"
                         x:Name="TextBoxDiagnostico"
                         Style="{StaticResource CampoStyle}"
                         Text="{Binding AtendimentoComando.Diagnostico, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         IsReadOnly="{Binding IsDiagnosticoReadOnly, Mode=OneWay}"
                         MinHeight="60"/>
            </Grid>

            <Separator Style="{StaticResource SeparadorStyle}"/>

            <!-- DADOS DO PACIENTE -->
            <TextBlock Text="Dados do Paciente"
                       Style="{StaticResource TituloSecaoStyle}"/>

            <Grid Style="{StaticResource GridCampoStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Nome Completo:"
                           Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Column="1"
                           Text="{Binding Atendimento.Paciente.NomeCompleto, Mode=OneWay, TargetNullValue='-', FallbackValue='-'}"
                           Style="{StaticResource ValorStyle}"/>
            </Grid>

            <Grid Style="{StaticResource GridCampoStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="CPF:"
                           Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Column="1"
                           Text="{Binding Atendimento.Paciente.CPF, Mode=OneWay, TargetNullValue='-', FallbackValue='-'}"
                           Style="{StaticResource ValorStyle}"/>
            </Grid>

            <Grid Style="{StaticResource GridCampoStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Data de Nascimento:"
                           Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Column="1"
                           Text="{Binding Atendimento.Paciente.DataNascimento, Mode=OneWay, StringFormat={}{0:dd/MM/yyyy}, TargetNullValue='-', FallbackValue='-'}"
                           Style="{StaticResource ValorStyle}"/>
            </Grid>

            <Grid Style="{StaticResource GridCampoStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Plano de Saúde:"
                           Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Column="1"
                           Text="{Binding Atendimento.Paciente.PlanoSaude, Mode=OneWay, TargetNullValue='-', FallbackValue='-'}"
                           Style="{StaticResource ValorStyle}"/>
            </Grid>

            <Grid Style="{StaticResource GridCampoStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Nº Carteirinha:"
                           Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Column="1"
                           Text="{Binding Atendimento.Paciente.NumeroCarteirinha, Mode=OneWay, TargetNullValue='-', FallbackValue='-'}"
                           Style="{StaticResource ValorStyle}"/>
            </Grid>

            <Separator Style="{StaticResource SeparadorStyle}"/>

            <!-- DADOS DO MÉDICO -->
            <TextBlock Text="Dados do Médico"
                       Style="{StaticResource TituloSecaoStyle}"/>

            <Grid Style="{StaticResource GridCampoStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Nome Completo - Matrícula:"
                           Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Column="1"
                           Text="{Binding Atendimento.Medico.NomeCompletoMatricula, Mode=OneWay, TargetNullValue='-', FallbackValue='-'}"
                           Style="{StaticResource ValorStyle}"/>
            </Grid>

            <Grid Style="{StaticResource GridCampoStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="CPF:"
                           Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Column="1"
                           Text="{Binding Atendimento.Medico.CPF, Mode=OneWay, TargetNullValue='-', FallbackValue='-'}"
                           Style="{StaticResource ValorStyle}"/>
            </Grid>

            <Grid Style="{StaticResource GridCampoStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="CRM:"
                           Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Column="1"
                           Text="{Binding Atendimento.Medico.CRM, Mode=OneWay, TargetNullValue='-', FallbackValue='-'}"
                           Style="{StaticResource ValorStyle}"/>
            </Grid>

            <Grid Style="{StaticResource GridCampoStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Especialidades:"
                           Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Column="1"
                           Text="{Binding Atendimento.Medico.EspecialidadesExibicao, Mode=OneWay, TargetNullValue='-', FallbackValue='-'}"
                           Style="{StaticResource ValorStyle}"/>
            </Grid>

            <Separator Style="{StaticResource SeparadorStyle}"/>

            <!-- DADOS DO ENFERMEIRO -->
            <TextBlock Text="Dados do Enfermeiro"
                       Style="{StaticResource TituloSecaoStyle}"/>

            <Grid Style="{StaticResource GridCampoStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Nome Completo - Matrícula:"
                           Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Column="1"
                           Text="{Binding Atendimento.Enfermeiro.NomeCompletoMatricula, Mode=OneWay, TargetNullValue='-', FallbackValue='-'}"
                           Style="{StaticResource ValorStyle}"/>
            </Grid>

            <Grid Style="{StaticResource GridCampoStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="CPF:"
                           Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Column="1"
                           Text="{Binding Atendimento.Enfermeiro.CPF, Mode=OneWay, TargetNullValue='-', FallbackValue='-'}"
                           Style="{StaticResource ValorStyle}"/>
            </Grid>

            <Grid Style="{StaticResource GridCampoStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="CRE:"
                           Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Column="1"
                           Text="{Binding Atendimento.Enfermeiro.CRE, Mode=OneWay, TargetNullValue='-', FallbackValue='-'}"
                           Style="{StaticResource ValorStyle}"/>
            </Grid>

            <Separator Style="{StaticResource SeparadorStyle}"/>

            <!-- BOTÃO SALVAR -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,16,0,0">

                <Button Content="Salvar"
                        Style="{StaticResource BotaoSalvarStyle}"
                        Click="SalvarAtendimento"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>

</Window>